#!/bin/bash
# ag-bridge — CLI tool for managing the Telegram ↔ Antigravity bridge (v2)
#
# Usage:
#   ag-bridge onboard     First-time setup — configure bot token and chat ID
#   ag-bridge configure   Edit an existing configuration value
#   ag-bridge start       Start the bot daemon
#   ag-bridge status      Show bot and CDP status
#   ag-bridge help        Show this help message

set -euo pipefail

AG_BRIDGE_HOME="${AG_BRIDGE_HOME:-$HOME/.ag-bridge}"
CONFIG_FILE="$AG_BRIDGE_HOME/config.json"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

usage() {
    echo -e "${BOLD}ag-bridge${NC} — Telegram ↔ Antigravity bridge (v2: CDP + HTTP callback)"
    echo ""
    echo "Usage:"
    echo "  ag-bridge onboard     First-time setup — configure bot token and chat ID"
    echo "  ag-bridge configure   Edit an existing configuration value"
    echo "  ag-bridge start       Start the bot daemon"
    echo "  ag-bridge status      Show bot and CDP status"
    echo "  ag-bridge help        Show this help message"
    echo ""
    echo "Prerequisite:"
    echo "  Antigravity must be launched with --remote-debugging-port=9222"
}

cmd_onboard() {
    echo -e "${BOLD}🤖 ag-bridge v2 — First-time setup${NC}"
    echo ""

    if [ -f "$CONFIG_FILE" ]; then
        echo -e "${YELLOW}Config already exists at $CONFIG_FILE${NC}"
        read -p "  Overwrite? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "  Use 'ag-bridge configure' to edit individual values."
            exit 0
        fi
    fi

    echo -e "  ${BOLD}Step 1:${NC} Create a Telegram bot"
    echo "    1. Open Telegram and search for @BotFather"
    echo "    2. Send /newbot and follow the prompts"
    echo "    3. Copy the bot token (e.g. 7123456789:AAHxxx...)"
    echo ""

    read -p "  Paste your bot token: " bot_token
    if [ -z "$bot_token" ]; then
        echo -e "${RED}Error:${NC} Bot token cannot be empty"
        exit 1
    fi

    echo ""
    echo -e "  ${BOLD}Step 2:${NC} Get your Telegram chat ID"
    echo "    1. Search for @RawDataBot on Telegram"
    echo "    2. Send it any message — it replies with your user ID"
    echo ""

    read -p "  Enter your chat ID (numeric): " chat_id
    if ! [[ "$chat_id" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Error:${NC} Chat ID must be a number"
        exit 1
    fi

    echo ""
    echo -e "  ${BOLD}Step 3:${NC} CDP and callback ports (press Enter for defaults)"
    echo ""

    read -p "  CDP port [9222]: " cdp_port
    cdp_port="${cdp_port:-9222}"

    read -p "  Callback port [3001]: " callback_port
    callback_port="${callback_port:-3001}"

    # Write config
    mkdir -p "$AG_BRIDGE_HOME"
    cat > "$CONFIG_FILE" <<EOF
{
  "bot_token": "$bot_token",
  "allowed_chat_ids": [$chat_id],
  "cdp_port": $cdp_port,
  "callback_port": $callback_port
}
EOF

    echo ""
    echo -e "${GREEN}✅ Config saved to $CONFIG_FILE${NC}"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo "    1. Launch Antigravity with: /Applications/Antigravity.app/Contents/MacOS/Antigravity --remote-debugging-port=$cdp_port"
    echo "    2. Start the bot: ag-bridge start"
}

cmd_configure() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Error:${NC} No config found. Run 'ag-bridge onboard' first."
        exit 1
    fi

    echo -e "${BOLD}ag-bridge — Configure${NC}"
    echo ""

    # Read current values
    local current_token current_chat_ids current_cdp_port current_callback_port
    current_token=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['bot_token'])" 2>/dev/null || echo "")
    current_chat_ids=$(python3 -c "import json; print(','.join(str(x) for x in json.load(open('$CONFIG_FILE'))['allowed_chat_ids']))" 2>/dev/null || echo "")
    current_cdp_port=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('cdp_port', 9222))" 2>/dev/null || echo "9222")
    current_callback_port=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('callback_port', 3001))" 2>/dev/null || echo "3001")

    echo "  What would you like to update?"
    echo ""
    echo "    1) Bot token       (current: ${current_token:0:10}...)"
    echo "    2) Chat ID(s)      (current: $current_chat_ids)"
    echo "    3) CDP port        (current: $current_cdp_port)"
    echo "    4) Callback port   (current: $current_callback_port)"
    echo "    5) Cancel"
    echo ""

    read -p "  Choose [1-5]: " choice
    echo ""

    case "$choice" in
        1)
            read -p "  New bot token: " new_token
            if [ -z "$new_token" ]; then
                echo -e "${RED}Error:${NC} Bot token cannot be empty"
                exit 1
            fi
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['bot_token'] = '$new_token'
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ Bot token updated.${NC}"
            ;;
        2)
            read -p "  New chat ID(s), comma-separated: " new_ids
            if [ -z "$new_ids" ]; then
                echo -e "${RED}Error:${NC} Chat ID cannot be empty"
                exit 1
            fi
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['allowed_chat_ids'] = [int(x.strip()) for x in '$new_ids'.split(',')]
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ Chat ID(s) updated.${NC}"
            ;;
        3)
            read -p "  New CDP port: " new_port
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['cdp_port'] = int('$new_port')
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ CDP port updated.${NC}"
            ;;
        4)
            read -p "  New callback port: " new_port
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['callback_port'] = int('$new_port')
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ Callback port updated.${NC}"
            ;;
        5|"")
            echo "  Cancelled."
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            exit 1
            ;;
    esac
}

cmd_start() {
    local bot="$AG_BRIDGE_HOME/bot.py"

    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Error:${NC} Config not found."
        echo "  Run 'ag-bridge onboard' to set up your bot token and chat ID."
        exit 1
    fi

    if [ ! -f "$bot" ]; then
        echo -e "${RED}Error:${NC} Bot script not found at $bot"
        exit 1
    fi

    echo -e "${BOLD}Starting ag-bridge v2...${NC}"
    python3 "$bot"
}

cmd_status() {
    local cdp_port
    cdp_port=$(python3 -c "import json; print(json.load(open('$AG_BRIDGE_HOME/config.json')).get('cdp_port', 9222))" 2>/dev/null || echo "9222")

    echo -e "${BOLD}ag-bridge v2 status${NC}"
    echo ""

    # Check if bot is running
    if pgrep -f "ag-bridge/bot.py" > /dev/null 2>&1; then
        echo -e "  Bot:  ${GREEN}● running${NC}"
    else
        echo -e "  Bot:  ${RED}● stopped${NC}"
    fi

    # Check CDP availability
    if curl -s --max-time 2 "http://localhost:$cdp_port/json/list" > /dev/null 2>&1; then
        echo -e "  CDP:  ${GREEN}● reachable${NC} (port $cdp_port)"
    else
        echo -e "  CDP:  ${RED}● not reachable${NC} (port $cdp_port)"
        echo "        Launch Antigravity with: --remote-debugging-port=$cdp_port"
    fi
}

# Main
case "${1:-help}" in
    onboard)   cmd_onboard ;;
    configure) cmd_configure ;;
    start)     cmd_start ;;
    status)    cmd_status ;;
    help|--help|-h) usage ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        echo ""
        usage
        exit 1
        ;;
esac
