#!/bin/bash
# ag-bridge — CLI tool for managing the Telegram ↔ Antigravity bridge
#
# Usage:
#   ag-bridge onboard     First-time setup — configure bot token and chat ID
#   ag-bridge configure   Edit an existing configuration value
#   ag-bridge init        Install the bridge-watcher skill into the current workspace
#   ag-bridge start       Start the bot daemon
#   ag-bridge status      Show bot and skill status
#   ag-bridge help        Show this help message

set -euo pipefail

AG_BRIDGE_HOME="${AG_BRIDGE_HOME:-$HOME/.ag-bridge}"
SKILL_SOURCE="$AG_BRIDGE_HOME/skill"
CONFIG_FILE="$AG_BRIDGE_HOME/config.json"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

usage() {
    echo -e "${BOLD}ag-bridge${NC} — Telegram ↔ Antigravity bridge"
    echo ""
    echo "Usage:"
    echo "  ag-bridge onboard     First-time setup — configure bot token and chat ID"
    echo "  ag-bridge configure   Edit an existing configuration value"
    echo "  ag-bridge init        Install the bridge-watcher skill into the current workspace"
    echo "  ag-bridge start       Start the bot daemon"
    echo "  ag-bridge status      Show bot status"
    echo "  ag-bridge help        Show this help message"
}

cmd_init() {
    local target_dir=".agent/skills/bridge-watcher"

    echo -e "${BOLD}Initializing ag-bridge in current workspace...${NC}"
    echo "  Workspace: $(pwd)"

    # Check if skill source exists
    if [ ! -d "$SKILL_SOURCE" ]; then
        echo -e "${RED}Error:${NC} Skill source not found at $SKILL_SOURCE"
        echo "  Make sure ag-bridge is installed at $AG_BRIDGE_HOME"
        exit 1
    fi

    # Check if already initialized
    if [ -d "$target_dir" ]; then
        echo -e "${YELLOW}Warning:${NC} bridge-watcher skill already exists at $target_dir"
        read -p "  Overwrite? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "  Aborted."
            exit 0
        fi
        rm -rf "$target_dir"
    fi

    # Create directory structure
    mkdir -p "$target_dir/scripts"

    # Copy skill files
    cp "$SKILL_SOURCE/SKILL.md" "$target_dir/SKILL.md"
    cp "$SKILL_SOURCE/scripts/bridge_client.py" "$target_dir/scripts/bridge_client.py"
    chmod +x "$target_dir/scripts/bridge_client.py"

    echo -e "${GREEN}✅ bridge-watcher skill installed at:${NC} $target_dir"
    echo ""
    echo "  Files added:"
    echo "    $target_dir/SKILL.md"
    echo "    $target_dir/scripts/bridge_client.py"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo "    1. Start the bot:  ag-bridge start"
    echo "    2. Open an Antigravity tab and say: \"Watch the bridge for remote commands\""
}

cmd_onboard() {
    echo -e "${BOLD}🤖 ag-bridge — First-time setup${NC}"
    echo ""

    if [ -f "$CONFIG_FILE" ]; then
        echo -e "${YELLOW}Config already exists at $CONFIG_FILE${NC}"
        read -p "  Overwrite? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "  Use 'ag-bridge configure' to edit individual values."
            exit 0
        fi
    fi

    echo -e "  ${BOLD}Step 1:${NC} Create a Telegram bot"
    echo "    1. Open Telegram and search for @BotFather"
    echo "    2. Send /newbot and follow the prompts"
    echo "    3. Copy the bot token (e.g. 7123456789:AAHxxx...)"
    echo ""

    read -p "  Paste your bot token: " bot_token
    if [ -z "$bot_token" ]; then
        echo -e "${RED}Error:${NC} Bot token cannot be empty"
        exit 1
    fi

    echo ""
    echo -e "  ${BOLD}Step 2:${NC} Get your Telegram chat ID"
    echo "    1. Search for @RawDataBot on Telegram"
    echo "    2. Send it any message — it replies with your user ID"
    echo ""

    read -p "  Enter your chat ID (numeric): " chat_id
    if ! [[ "$chat_id" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Error:${NC} Chat ID must be a number"
        exit 1
    fi

    # Write config
    cat > "$CONFIG_FILE" <<EOF
{
  "bot_token": "$bot_token",
  "allowed_chat_ids": [$chat_id],
  "socket_path": "~/.ag-bridge/bridge.sock"
}
EOF

    echo ""
    echo -e "${GREEN}✅ Config saved to $CONFIG_FILE${NC}"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo "    1. Install the skill:  ag-bridge init"
    echo "    2. Start the bot:     ag-bridge start"
    echo "    3. Open an Antigravity tab and say: \"Watch the bridge for remote commands\""
}

cmd_configure() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Error:${NC} No config found. Run 'ag-bridge onboard' first."
        exit 1
    fi

    echo -e "${BOLD}ag-bridge — Configure${NC}"
    echo ""

    # Read current values
    local current_token current_chat_ids
    current_token=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['bot_token'])" 2>/dev/null || echo "")
    current_chat_ids=$(python3 -c "import json; print(','.join(str(x) for x in json.load(open('$CONFIG_FILE'))['allowed_chat_ids']))" 2>/dev/null || echo "")

    echo "  What would you like to update?"
    echo ""
    echo "    1) Bot token     (current: ${current_token:0:10}...)"
    echo "    2) Chat ID(s)    (current: $current_chat_ids)"
    echo "    3) Cancel"
    echo ""

    read -p "  Choose [1-3]: " choice
    echo ""

    case "$choice" in
        1)
            read -p "  New bot token: " new_token
            if [ -z "$new_token" ]; then
                echo -e "${RED}Error:${NC} Bot token cannot be empty"
                exit 1
            fi
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['bot_token'] = '$new_token'
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ Bot token updated.${NC}"
            ;;
        2)
            read -p "  New chat ID(s), comma-separated: " new_ids
            if [ -z "$new_ids" ]; then
                echo -e "${RED}Error:${NC} Chat ID cannot be empty"
                exit 1
            fi
            python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    config = json.load(f)
config['allowed_chat_ids'] = [int(x.strip()) for x in '$new_ids'.split(',')]
with open('$CONFIG_FILE', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\\n')
"
            echo -e "${GREEN}✅ Chat ID(s) updated.${NC}"
            ;;
        3|"")
            echo "  Cancelled."
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            exit 1
            ;;
    esac
}

cmd_start() {
    local bot="$AG_BRIDGE_HOME/bot.py"

    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Error:${NC} Config not found."
        echo "  Run 'ag-bridge onboard' to set up your bot token and chat ID."
        exit 1
    fi

    if [ ! -f "$bot" ]; then
        echo -e "${RED}Error:${NC} Bot script not found at $bot"
        exit 1
    fi

    echo -e "${BOLD}Starting ag-bridge bot...${NC}"
    python3 "$bot"
}

cmd_status() {
    local socket_path
    socket_path=$(python3 -c "import json,os; c=json.load(open(os.path.expanduser('$AG_BRIDGE_HOME/config.json'))); print(os.path.expanduser(c.get('socket_path','~/.ag-bridge/bridge.sock')))" 2>/dev/null || echo "$AG_BRIDGE_HOME/bridge.sock")

    echo -e "${BOLD}ag-bridge status${NC}"
    echo ""

    # Check if bot is running
    if pgrep -f "ag-bridge/bot.py" > /dev/null 2>&1; then
        echo -e "  Bot:    ${GREEN}● running${NC}"
    else
        echo -e "  Bot:    ${RED}● stopped${NC}"
    fi

    # Check socket
    if [ -S "$socket_path" ]; then
        echo -e "  Socket: ${GREEN}● exists${NC} ($socket_path)"
    else
        echo -e "  Socket: ${RED}● not found${NC}"
    fi

    # Check skill in current workspace
    if [ -d ".agent/skills/bridge-watcher" ]; then
        echo -e "  Skill:  ${GREEN}● installed${NC} ($(pwd)/.agent/skills/bridge-watcher)"
    else
        echo -e "  Skill:  ${YELLOW}● not installed${NC} in current workspace"
        echo "          Run 'ag-bridge init' to install"
    fi
}

# Main
case "${1:-help}" in
    onboard)   cmd_onboard ;;
    configure) cmd_configure ;;
    init)      cmd_init ;;
    start)     cmd_start ;;
    status)    cmd_status ;;
    help|--help|-h) usage ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        echo ""
        usage
        exit 1
        ;;
esac
